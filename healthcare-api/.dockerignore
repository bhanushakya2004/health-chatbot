# .dockerignore for backend
# Prevent copying unnecessary files to Docker context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
eggs/
.eggs/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Logs
logs/
*.log

# Database
*.db
*.sqlite

# ChromaDB
data/chromadb/*

# Uploads
uploads/*

# Testing
.pytest_cache/
.coverage
htmlcov/

# Documentation
*.md
docs/

# Batch files (Windows only)
*.bat
