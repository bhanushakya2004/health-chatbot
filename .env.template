# Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================
# AI MODEL API KEYS (Required)
# ============================================
# Provide at least ONE of the following API keys:

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# DeepSeek API Key (Alternative to Gemini)
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here


# ============================================
# SECURITY (Required for Production)
# ============================================
# JWT secret key for token signing
# Generate secure key: openssl rand -hex 32
# MUST be at least 32 characters
SECRET_KEY=change-this-to-a-very-long-random-secret-key-min-32-chars


# ============================================
# DATABASE (Optional - has defaults)
# ============================================
# MongoDB connection URL
# Default: mongodb://localhost:27017 (local)
# Docker: mongodb://mongo:27017 (container)
# Cloud: mongodb+srv://user:pass@cluster.mongodb.net
MONGODB_URL=mongodb://localhost:27017

# Database name
DATABASE_NAME=healthcare_db


# ============================================
# AUTHENTICATION (Optional)
# ============================================
# JWT token expiration time in minutes
# Default: 30 minutes
# Recommended: 60 (1 hour) for better UX
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ============================================
# FRONTEND (Optional)
# ============================================
# Backend API URL for frontend
# Development: http://localhost:8000
# Production: https://your-api-domain.com
VITE_API_BASE_URL=http://localhost:8000


# ============================================
# TESSERACT OCR (Optional - Windows only)
# ============================================
# Path to Tesseract executable (if not in PATH)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Mac: /usr/local/bin/tesseract
# Linux: /usr/bin/tesseract
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe


# ============================================
# LOGGING (Optional)
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file location
LOG_FILE=logs/app.log


# ============================================
# PRODUCTION SETTINGS (Optional)
# ============================================
# Enable production mode
# PRODUCTION=true

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate limiting
# MAX_REQUESTS_PER_MINUTE=60


# ============================================
# NOTES
# ============================================
# 1. Never commit this file with real credentials
# 2. Keep SECRET_KEY secure and unique per environment
# 3. Use strong, randomly generated keys
# 4. For production, use environment variables or secrets management
# 5. Rotate keys regularly for security
